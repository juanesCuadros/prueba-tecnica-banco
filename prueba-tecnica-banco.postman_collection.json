{
  "info": {
    "name": "Prueba Técnica Banco",
    "_postman_id": "prueba-tecnica-banco-v1",
    "description": "Colección completa para prueba técnica de microservicios bancarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseCliente", "value": "http://localhost:8080/api" },
    { "key": "baseCuenta",  "value": "http://localhost:8081/api" }
  ],
  "item": [
    {
      "name": "1. Cliente-Persona Service",
      "item": [
        {
          "name": "1.1 Crear Cliente - Jose Lema",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseCliente}}/clientes", "host": ["{{baseCliente}}"], "path": ["clientes"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 35,\n  \"identificacion\": \"1234567890\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"098254785\",\n  \"clienteId\": \"jlema\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            }
          }
        },
        {
          "name": "1.2 Crear Cliente - Marianela Montalvo",
